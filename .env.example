# Copy to .env and fill in (never commit .env).
# Or set the same names in your system environment.

MT5_LOGIN=
MT5_PASSWORD=
MT5_SERVER=
# If MT5 is already logged in manually, set to 1 to skip mt5.login (avoids IPC timeout / double login).
# MT5_USE_EXISTING_SESSION=1
# Optional: path to terminal64.exe if Python cannot find MT5 automatically
# MT5_TERMINAL_PATH=C:\Program Files\MetaTrader 5\terminal64.exe
